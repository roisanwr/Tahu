# ============================================================
# BACKEND — Environment Variables
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit file .env ke git!
# ============================================================

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Dari: Supabase Dashboard → Settings → API → service_role

# Gemini AI
GEMINI_API_KEY=AIzaSy...                # Dari: aistudio.google.com/app/apikey

# Azure AI Document Intelligence
AZURE_DOCUMENT_KEY=xxxxxxxxxxxxxxxx     # Dari: Azure Portal → Resource → Keys and Endpoint
AZURE_DOCUMENT_ENDPOINT=https://xxxx.cognitiveservices.azure.com/

# CORS — Pisahkan dengan koma jika lebih dari satu origin
ALLOWED_ORIGINS=http://localhost:3000

# App Config
APP_ENV=development                     # development | production
APP_VERSION=0.1.0
