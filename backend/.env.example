# ============================================================
# BACKEND — Environment Variables
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit file .env ke git!
# ============================================================

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...           # Dari: Supabase Dashboard → Settings → API → anon
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Dari: Supabase Dashboard → Settings → API → service_role
SUPABASE_JWT_SECRET=                    # Opsional — dari Supabase JWT Settings

# NVIDIA NIM — Dual Model Setup
# Dapatkan API key di: https://build.nvidia.com

# Model 1: z-ai/glm4.7 — untuk chat interview RINA (real-time, lebih cepat)
NVIDIA_CHAT_API_KEY=nvapi-...
NVIDIA_CHAT_MODEL=z-ai/glm4.7

# Model 2: deepseek-ai/deepseek-v4-pro — untuk ekstraksi data & scoring pipeline
NVIDIA_EXTRACT_API_KEY=nvapi-...
NVIDIA_EXTRACT_MODEL=deepseek-ai/deepseek-v4-pro

# Azure AI Document Intelligence (opsional — stub mode jika tidak diisi)
AZURE_DOCUMENT_KEY=xxxxxxxxxxxxxxxx     # Dari: Azure Portal → Resource → Keys and Endpoint
AZURE_DOCUMENT_ENDPOINT=https://xxxx.cognitiveservices.azure.com/

# GitHub Models (Primary AI Provider — opsional)
# Jika diisi, GitHub Models digunakan sebagai provider utama. NVIDIA menjadi fallback otomatis.
# Jika dikosongkan, sistem tetap jalan menggunakan NVIDIA saja.
GITHUB_TOKEN=                           # GitHub Personal Access Token (PAT)
GITHUB_MODEL=gpt-4o-mini

# CORS — Pisahkan dengan koma jika lebih dari satu origin
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# App Config
APP_ENV=development                     # development | production
APP_VERSION=0.1.0
